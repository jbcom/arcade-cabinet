{
  "name": "arcade-cabinet",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "corepack pnpm -r run build",
    "dev": "corepack pnpm -r --parallel run dev",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "corepack pnpm -r run typecheck",
    "clean": "corepack pnpm -r run clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.52.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
