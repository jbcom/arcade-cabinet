---
import GameIsland from "../../components/GameIsland";
import { type Game, games } from "../../games/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBasePath } from "../../utils/basePath";

export function getStaticPaths() {
  return games.map((game) => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

interface Props {
  game: Game;
}

const { game } = Astro.props;
---

<BaseLayout
  title={`${game.title} | Arcade Cabinet`}
  description={`${game.description} Play ${game.title} as a React island inside the Astro arcade cabinet.`}
>
  <main class="fixed inset-0 w-full h-[100svh] overflow-hidden bg-black touch-none select-none">
    <a
      class="fixed left-4 top-4 z-50 border border-slate-700 bg-slate-950/80 px-4 py-2 font-mono text-[0.7rem] uppercase text-slate-200 backdrop-blur transition hover:border-cyan-400 hover:text-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-300"
      href={withBasePath("/#games")}
    >
      Cabinet
    </a>
    <GameIsland slug={game.slug} client:only="react" />
  </main>
</BaseLayout>
